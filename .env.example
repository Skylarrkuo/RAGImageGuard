# ============================================================
# .env 配置模板 — 复制为 .env 并填入你的 API Key
# ============================================================

# ---- 安全配置 ----
# API 访问密钥（留空=不启用认证，生产环境务必设置）
API_KEY=
# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8001
# 上传文件大小限制（MB）
MAX_UPLOAD_MB=20

# MaxKB 场景优化专用智能体
MAXKB_SCENE_OPTIMIZE_BASE_URL=
MAXKB_SCENE_OPTIMIZE_API_KEY=

# MiMo 视觉 / LLM API
MIMO_API_KEY=
MIMO_API_BASE=

# OpenAI API（图片编辑）
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL_NAME=gpt-5.4-mini
